<UserControl x:Class="StockCap.Visual.Wpf.InputDevicesKeysDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StockCap.Visual.Wpf"
             mc:Ignorable="d">
    <StackPanel x:Name="_keyDisplayPanel" Orientation="Horizontal">
        <TextBlock x:Name="_modifierKeyTextBlock"/>
        <TextBlock x:Name="_keyTextBlock"/>
        <TextBlock x:Name="_mouseLeftButtonTextBlock"/>
        <TextBlock x:Name="_mouseRightButtonTextBlock"/>
        <TextBlock x:Name="_mouseMiddleButtonTextBlock"/>
    </StackPanel>
</UserControl>
